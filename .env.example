# AI_gf_momo 环境变量配置
# 复制此文件为 .env 并填入你的配置

# LLM 配置
LLM_API_KEY=your-api-key-here
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com/v1

# ComfyUI 配置
COMFYUI_HOST=127.0.0.1
COMFYUI_PORT=8188

# TTS 配置 (Minimax)
TTS_API_KEY=your-minimax-api-key
TTS_GROUP_ID=your-group-id

# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
